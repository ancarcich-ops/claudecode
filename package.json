{
  "name": "sticks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "use:postgres": "node scripts/use-postgres.mjs",
    "build:vercel": "node scripts/use-postgres.mjs && prisma generate && prisma db push --skip-generate && (tsx scripts/import-course-ratings.ts scripts/course-ratings.csv --skip-if-current || echo '[ratings] import step skipped (non-fatal)') && next build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@deck.gl/core": "^9.3.4",
    "@deck.gl/geo-layers": "^9.3.4",
    "@deck.gl/layers": "^9.3.4",
    "@deck.gl/react": "^9.3.4",
    "@loaders.gl/3d-tiles": "^4.4.3",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-select": "^2.2.6",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/mapbox-gl": "^3.4.1",
    "@vercel/blob": "^2.3.3",
    "aws4": "^1.13.2",
    "boring-avatars": "^2.0.4",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "mapbox-gl": "^3.24.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/aws4": "^1.11.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
