DATABASE_URL="file:./dev.db"
# Public Mapbox token (pk.*). When set, on-course mini-map renders a
# satellite base layer. Get one free at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=
# Comma-separated list of usernames allowed into /admin/* routes.
# Example: ADMIN_USERNAMES="seuss,jordan"
ADMIN_USERNAMES=

# GolfBert API credentials (server-only -- never NEXT_PUBLIC_*). All
# three are required; AWS SigV4 signs every request with the access /
# secret pair and the x-api-key header carries the API token.
GOLFBERT_API_KEY=
GOLFBERT_ACCESS_KEY=
GOLFBERT_SECRET_KEY=
