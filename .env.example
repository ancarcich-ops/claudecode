DATABASE_URL="file:./dev.db"
# Public Mapbox token (pk.*). When set, on-course mini-map renders a
# satellite base layer. Get one free at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=
# Comma-separated list of usernames allowed into /admin/* routes.
# Example: ADMIN_USERNAMES="seuss,jordan"
ADMIN_USERNAMES=
