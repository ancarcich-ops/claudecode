# --- Local development (SQLite) ---
# Leave as-is for local dev; `npm run db:push` creates prisma/dev.db.
DATABASE_URL="file:./dev.db"

# --- Production (Vercel + Supabase) ---
# Supabase dashboard → "Connect" → ORMs → Prisma shows both of these exactly.
# Set BOTH in Vercel → Settings → Environment Variables:
#
# DATABASE_URL = transaction pooler (port 6543), used by the app at runtime:
# DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = direct connection (port 5432), used to create tables at build:
# DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Photos (optional) ---
# Create a Vercel Blob store (Vercel dashboard → Storage → Blob) and this
# token is injected automatically. Without it, the app simply hides photo
# uploads — everything else works.
# BLOB_READ_WRITE_TOKEN=
