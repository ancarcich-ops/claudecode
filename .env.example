DATABASE_URL="file:./dev.db"
# Public Mapbox token (pk.*). When set, on-course mini-map renders a
# satellite base layer. Get one free at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=
# Comma-separated list of usernames allowed into /admin/* routes.
# Example: ADMIN_USERNAMES="seuss,jordan"
ADMIN_USERNAMES=

# GolfBert API credentials (server-only -- never NEXT_PUBLIC_*). All
# three are required; AWS SigV4 signs every request with the access /
# secret pair and the x-api-key header carries the API token.
GOLFBERT_API_KEY=
GOLFBERT_ACCESS_KEY=
GOLFBERT_SECRET_KEY=

# Auth: password-reset emails via Resend (https://resend.com).
# RESEND_API_KEY enables sending; without it, reset requests succeed
# silently (no email) so dev still works. RESEND_FROM must be on a
# domain you've verified in Resend (falls back to Resend's onboarding
# sender, which only delivers to your own account email).
RESEND_API_KEY=
RESEND_FROM="Sticks <no-reply@yourdomain.com>"
# Public base URL used to build reset links (no trailing slash).
# Falls back to VERCEL_URL, then localhost.
APP_URL=

# WebAuthn / passkey ("Sign in with Face ID") config. rpId MUST match
# the deployed domain (e.g. sticks-app.vercel.app). rpName is the app
# name shown in the OS prompt. expectedOrigin is derived from rpId but
# can be pinned with WEBAUTHN_ORIGIN for non-standard setups.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME="Sticks"
WEBAUTHN_ORIGIN=
