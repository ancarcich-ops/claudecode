// Bloom — Geena's pregnancy craving tracker (local SQLite dev schema).
// Production uses prisma/schema.postgres.prisma (Supabase Postgres) — the
// Vercel build runs `npm run use:postgres` to swap this file before build.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Craving {
  id          String   @id @default(cuid())
  food        String
  // sweet | salty | sour | savory | spicy | carbs | fruit | dairy | drink | other
  category    String   @default("other")
  intensity   Int      @default(3) // 1-5 hearts
  loggedBy    String   @default("geena") // geena | daddy
  satisfied   Boolean  @default(false)
  satisfiedBy String? // geena | daddy | takeout
  isWild      Boolean  @default(false)
  stars       Int      @default(0) // hall-of-fame rating for wild combos (0-5)
  notes       String?
  photoUrl    String?
  week        Int? // pregnancy week when the craving struck
  trimester   Int? // 1 | 2 | 3
  cravedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([cravedAt])
  @@index([isWild])
}

model Aversion {
  id        String   @id @default(cuid())
  food      String
  severity  Int      @default(3) // 1-5 how repulsive
  loggedBy  String   @default("geena")
  notes     String?
  week      Int?
  trimester Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Settings {
  id          String    @id @default("singleton")
  dueDate     DateTime?
  momName     String    @default("Mom")
  partnerName String    @default("Partner")
  babyName    String?
  palette     String    @default("blush") // accent color theme (see lib/palettes)
  updatedAt   DateTime  @default(now()) @updatedAt
}
