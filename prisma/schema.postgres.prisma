// Bloom — Postgres variant of the schema (Supabase / Vercel Postgres / Neon).
// `npm run use:postgres` copies this over prisma/schema.prisma before the
// Vercel build so production always uses the postgresql provider.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler, port 6543) for the app's
  // serverless queries.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by `prisma db push` at build time —
  // schema changes can't run over the pooler.
  directUrl = env("DIRECT_URL")
}

model Craving {
  id          String   @id @default(cuid())
  food        String
  category    String   @default("other")
  intensity   Int      @default(3)
  loggedBy    String   @default("geena")
  satisfied   Boolean  @default(false)
  satisfiedBy String?
  isWild      Boolean  @default(false)
  stars       Int      @default(0)
  notes       String?
  photoUrl    String?
  week        Int?
  trimester   Int?
  cravedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([cravedAt])
  @@index([isWild])
}

model Aversion {
  id        String   @id @default(cuid())
  food      String
  severity  Int      @default(3)
  loggedBy  String   @default("geena")
  notes     String?
  week      Int?
  trimester Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Settings {
  id          String    @id @default("singleton")
  dueDate     DateTime?
  momName     String    @default("Mom")
  partnerName String    @default("Partner")
  babyName    String?
  palette     String    @default("blush")
  updatedAt   DateTime  @default(now()) @updatedAt
}
