// Sticks - Postgres variant of the schema.
// Used for production deploys (Vercel + Neon/Supabase/Vercel Postgres).
// `npm run use:postgres` copies this over prisma/schema.prisma before build.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String?
  createdAt   DateTime @default(now())

  createdMatches   Match[]       @relation("MatchCreator")
  playerSeats      MatchPlayer[]
  wagers           Wager[]
  createdGroups    Group[]       @relation("GroupCreator")
  groupMemberships GroupMember[]
}

model Group {
  id          String        @id @default(cuid())
  name        String
  slug        String?       @unique
  inviteCode  String        @unique
  createdById String
  createdBy   User          @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())

  members     GroupMember[]
  matches     Match[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Match {
  id           String      @id @default(cuid())
  courseName   String
  scheduledAt  DateTime
  holes        Int         @default(18)
  status       String      @default("UPCOMING")
  scoringMode  String      @default("NET")
  parData      String?
  createdById  String
  createdBy    User        @relation("MatchCreator", fields: [createdById], references: [id])
  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?

  players      MatchPlayer[]
  wagers       Wager[]
  oddsSnapshots OddsSnapshot[]
  sideGames    SideGame[]
}

model SideGame {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  kind      String
  config    String?
  createdAt DateTime @default(now())

  events    SideGameEvent[]

  @@unique([matchId, kind])
  @@index([matchId])
}

model SideGameEvent {
  id            String       @id @default(cuid())
  sideGameId    String
  sideGame      SideGame     @relation(fields: [sideGameId], references: [id], onDelete: Cascade)
  hole          Int
  kind          String
  matchPlayerId String?
  matchPlayer   MatchPlayer? @relation(fields: [matchPlayerId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@unique([sideGameId, hole, kind, matchPlayerId])
  @@index([sideGameId, hole])
}

model MatchPlayer {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  displayName String
  handicap    Float
  seat        Int

  scores      ScoreEntry[]
  wagers      Wager[]
  oddsSnapshots OddsSnapshot[]
  sideGameEvents SideGameEvent[]

  @@unique([matchId, seat])
}

model ScoreEntry {
  id            String      @id @default(cuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  hole          Int
  strokes       Int
  createdAt     DateTime    @default(now())

  @@unique([matchPlayerId, hole])
}

model Wager {
  id              String      @id @default(cuid())
  matchId         String
  match           Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  pickedPlayerId  String
  pickedPlayer    MatchPlayer @relation(fields: [pickedPlayerId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())

  @@unique([matchId, userId])
}

model OddsSnapshot {
  id            String      @id @default(cuid())
  matchId       String
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  probability   Float
  createdAt     DateTime    @default(now())

  @@index([matchId, createdAt])
}
