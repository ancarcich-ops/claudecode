// Sticks - Postgres variant of the schema.
// Used for production deploys (Vercel + Neon/Supabase/Vercel Postgres).
// `npm run use:postgres` copies this over prisma/schema.prisma before build.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  // Email + password for proper auth. Nullable at the DB level so the
  // column can be added to an existing table without a destructive
  // migration, but REQUIRED at the application layer (signup always
  // sets both). email is unique among non-null values.
  email        String?  @unique
  passwordHash String?
  displayName String?
  avatarSeed    String?
  avatarVariant String?
  avatarUrl     String?
  ghinNumber  String?
  createdAt   DateTime @default(now())

  createdMatches      Match[]            @relation("MatchCreator")
  playerSeats         MatchPlayer[]
  wagers              Wager[]
  createdGroups       Group[]            @relation("GroupCreator")
  groupMemberships    GroupMember[]
  sessions            Session[]
  passwordResets      PasswordResetToken[]
  passkeys            Passkey[]
  createdTournaments  Tournament[]       @relation("TournamentCreator")
  tournamentEntries   TournamentPlayer[]
}

// WebAuthn / passkey credentials. Each row is one device (Face ID on
// iPhone, Touch ID on Mac, etc.) the user enrolled. publicKey is the
// base64url-encoded COSE public key bytes; we verify assertion
// signatures against it on sign-in. counter is bumped after each
// successful auth (replay protection).
model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  transports   String?
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

// Short-lived registration / authentication challenge. Stored in DB so
// it survives across Vercel serverless instances. Cleaned up on use or
// after expiresAt. userId is null for the auth flow (we don't know the
// user yet -- discoverable credentials resolve them after the assertion).
model WebauthnChallenge {
  id        String   @id @default(cuid())
  userId    String?
  challenge String   @unique
  kind      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// One-time password reset tokens, emailed to the user as a link.
// Single-use (usedAt set on redemption) and short-lived (expiresAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  slug        String?       @unique
  inviteCode  String        @unique
  createdById String
  createdBy   User          @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())

  members     GroupMember[]
  matches     Match[]
  tournaments Tournament[]
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}

model Match {
  id           String      @id @default(cuid())
  courseName   String
  scheduledAt  DateTime
  holes        Int         @default(18)
  startingHole Int         @default(1)
  status       String      @default("UPCOMING")
  scoringMode  String      @default("NET")
  // "INDIVIDUAL" (every player against every player) or "SCRAMBLE"
  // (2 teams; one score per team per hole). Default INDIVIDUAL to
  // keep existing matches unchanged.
  format       String      @default("INDIVIDUAL")
  // Scramble-only settings JSON: handicapMode + optional teamNames.
  // Null for INDIVIDUAL matches.
  scrambleConfig String?
  parData      String?
  createdById  String
  createdBy    User        @relation("MatchCreator", fields: [createdById], references: [id])
  groupId      String?
  group        Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  // When this match is round N of a tournament, both columns are set.
  // Null on standalone (non-tournament) matches. SetNull on tournament
  // delete so the play history isn't lost.
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  roundNumber  Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  winnerSummary String?

  players      MatchPlayer[]
  wagers       Wager[]
  oddsSnapshots OddsSnapshot[]
  sideGames    SideGame[]

  @@index([tournamentId, roundNumber])
}

// Multi-round tournament container. Holds N matches (each tagged with
// tournamentId + roundNumber), a fixed roster of players, and a
// cumulative leaderboard derived from the child matches' scores.
// MVP: no cuts, scoring mode applies to every round, players can be
// linked Sticks users or free-typed names (same as MatchPlayer).
model Tournament {
  id               String   @id @default(cuid())
  name             String
  // Share code anyone can join with -- mirrors Group.inviteCode.
  // Tournaments aren't tied to a group, so this is how the creator
  // pulls 16 players from across 4 different foursomes into the
  // same standings. Nullable at the DB level for safe additive
  // migration; uniqueness enforced in createTournamentAction's
  // retry-on-collision generator (an @@index below makes the lookup
  // fast). Not @unique because `prisma db push` refuses to add a
  // unique constraint to a populated column without
  // --accept-data-loss, which we keep off the build script as a
  // hard rule. A future SQL migration can promote this once the
  // column is clean.
  inviteCode       String?
  // NET (handicap applied per round) or GROSS (raw stroke totals
  // summed). Same mode applied to every round; child matches still
  // carry their own scoringMode but the leaderboard rolls up using
  // this one.
  scoringMode      String   @default("NET")
  // Soft target -- the creator can add more rounds later. Actual
  // rounds tracked via the matches[] relation; this is just so the
  // detail page can render "Round 3 of 4" expected progress.
  roundsPlanned    Int      @default(2)
  scheduledStartAt DateTime?
  // UPCOMING / IN_PROGRESS / COMPLETED.
  status           String   @default("UPCOMING")
  createdById      String
  createdBy        User     @relation("TournamentCreator", fields: [createdById], references: [id])
  // Group scope. "public" is a real Group row so this is required
  // semantically; we keep it nullable for parity with Match.
  groupId          String?
  group            Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  completedAt      DateTime?
  notes            String?

  matches          Match[]
  roster           TournamentPlayer[]

  @@index([groupId, createdAt])
  @@index([inviteCode])
}

// One entry in a tournament's roster. Same signup shape as
// MatchPlayer: every round's match pulls these names into its own
// players[] list at creation. handicapAtStart captures the player's
// Sticks index when they joined so leaderboard math stays stable
// even if their live handicap shifts during the event.
model TournamentPlayer {
  id              String     @id @default(cuid())
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  displayName     String
  // Optional link to a real Sticks account; free-typed names have
  // userId = null.
  userId          String?
  user            User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Pre-tournament handicap snapshot. Null if the player has no
  // index yet (under 3 logged rounds).
  handicapAtStart Float?
  createdAt       DateTime   @default(now())

  @@index([tournamentId])
  @@unique([tournamentId, displayName])
}

model SideGame {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  kind      String
  config    String?
  createdAt DateTime @default(now())

  events    SideGameEvent[]

  @@unique([matchId, kind])
  @@index([matchId])
}

model SideGameEvent {
  id            String       @id @default(cuid())
  sideGameId    String
  sideGame      SideGame     @relation(fields: [sideGameId], references: [id], onDelete: Cascade)
  hole          Int
  kind          String
  matchPlayerId String?
  matchPlayer   MatchPlayer? @relation(fields: [matchPlayerId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@unique([sideGameId, hole, kind, matchPlayerId])
  @@index([sideGameId, hole])
}

model MatchPlayer {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  displayName String
  handicap    Float
  seat        Int
  // Team assignment for scramble matches: 0 = Team A, 1 = Team B.
  // Null for INDIVIDUAL matches.
  team        Int?

  scores      ScoreEntry[]
  wagers      Wager[]
  oddsSnapshots OddsSnapshot[]
  sideGameEvents SideGameEvent[]

  @@unique([matchId, seat])
}

model ScoreEntry {
  id            String      @id @default(cuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  hole          Int
  strokes       Int
  createdAt     DateTime    @default(now())

  @@unique([matchPlayerId, hole])
}

model Wager {
  id              String      @id @default(cuid())
  matchId         String
  match           Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  pickedPlayerId  String
  pickedPlayer    MatchPlayer @relation(fields: [pickedPlayerId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())

  @@unique([matchId, userId])
}

model OddsSnapshot {
  id            String      @id @default(cuid())
  matchId       String
  match         Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  probability   Float
  createdAt     DateTime    @default(now())

  @@index([matchId, createdAt])
}

model Course {
  id        String         @id @default(cuid())
  name      String         @unique
  centerLat Float?
  centerLng Float?
  osmFetchedAt DateTime?
  parData   String?
  createdAt DateTime       @default(now())

  holes     CourseHole[]
  hazards   CourseHazard[]
}

model CourseHazard {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hole      Int
  kind      String
  label     String?
  lat       Float
  lng       Float
  contributedById String?
  createdAt DateTime @default(now())

  @@index([courseId, hole])
}

model CourseHole {
  id        String  @id @default(cuid())
  courseId  String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hole      Int
  greenLat  Float?
  greenLng  Float?
  greenFrontLat  Float?
  greenFrontLng  Float?
  greenBackLat   Float?
  greenBackLng   Float?
  teeLat    Float?
  teeLng    Float?
  greenPolygonJson   String?
  fairwayPolygonJson String?
  distanceYds Int?
  contributedById String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([courseId, hole])
  @@index([courseId])
}
