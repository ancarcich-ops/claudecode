# Braves Minors Tracker — environment configuration

# Force the mock dataset instead of hitting the live MLB Stats API.
# Useful for local dev in network-restricted sandboxes. Set to "1" to enable.
# When unset, the app calls the live API and only falls back to mock on error.
USE_MOCK_DATA=

# Season the app reports on. Defaults to the current calendar year.
SEASON=2026

# (Reserved for upcoming milestones)
# Postgres connection string used by Prisma for snapshots / prospects.
# DATABASE_URL=
# Secret required to invoke the daily ingestion cron endpoint.
# CRON_SECRET=
